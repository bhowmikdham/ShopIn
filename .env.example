# ╔══════════════════════════════════════════════════════════════╗
# ║  ShopIn Environment Variables                               ║
# ║  Copy this file to .env and fill in your values             ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Firebase (Client) ────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → General → Your Apps → Web App
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Firebase (Server) ───────────────────────────────────────
# Option A: Service Account JSON (download from Firebase Console → Project Settings → Service Accounts)
# Paste the entire JSON as a single line:
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B: Just the project ID (works with Application Default Credentials on GCP)
FIREBASE_PROJECT_ID=your-project-id

# ── MySQL / Drizzle (Legacy — optional if using Firebase) ────
DATABASE_URL=

# ── Original OAuth (Legacy — optional if using Firebase Auth) ─
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
OAUTH_SERVER_URL=
JWT_SECRET=
OWNER_OPEN_ID=

# ── Built-in Forge API (optional) ───────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
